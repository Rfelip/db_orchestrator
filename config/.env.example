# Database connection
DB_DIALECT=oracle+oracledb        # or postgresql+psycopg2
DB_HOST=localhost
DB_PORT=1521
DB_USER=your_db_user
DB_PASS=your_db_password
DB_SERVICE=your_service_name       # Oracle only
DB_DATABASE=your_database_name     # PostgreSQL only

# Oracle options
USE_DIAGNOSTICS_PACK=true          # Enable AWR/ASH profiling (requires license)
ORACLE_CLIENT_DIR=                 # Path to Oracle Instant Client (optional, uses default if empty)

# Notifications — both channels optional and independent.
# If both are configured, alerts fan out to both. If neither, the
# orchestrator runs silently (warning at startup).

# Discord (channel webhook)
DISCORD_WEBHOOK_URL=

# Telegram (bot token + chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

USER_NAME=your_name


# Named DB targets (optional). Lets callers say
# `run_sql("...", target="MR3")` without spelling out transport
# details. Each target is a set of `DB_TARGET_<NAME>_<FIELD>` keys.
#
# Example: pgduckdb running in a docker container on a remote WSL host,
# reachable only via SSH (Tailscale terminates at the Windows host so
# the container's port is not visible to outside callers).
#
# DB_TARGET_MR3_TRANSPORT=ssh+wsl
# DB_TARGET_MR3_SSH=adm@100.95.184.17
# DB_TARGET_MR3_CONTAINER=pgduckdb
# DB_TARGET_MR3_PG_USER=postgres
# DB_TARGET_MR3_PG_DATABASE=labma_benchmark
# DB_TARGET_MR3_WSL=true
# DB_TARGET_MR3_SUDO=true
#
# Direct (SQLAlchemy) target — local Postgres or any reachable host.
#
# DB_TARGET_LOCAL_TRANSPORT=direct
# DB_TARGET_LOCAL_DIALECT=postgresql+psycopg2
# DB_TARGET_LOCAL_USER=postgres
# DB_TARGET_LOCAL_PASSWORD=
# DB_TARGET_LOCAL_HOST=localhost
# DB_TARGET_LOCAL_PORT=5432
# DB_TARGET_LOCAL_DATABASE=labma
