# Database connection
DB_DIALECT=oracle+oracledb        # or postgresql+psycopg2
DB_HOST=localhost
DB_PORT=1521
DB_USER=your_db_user
DB_PASS=your_db_password
DB_SERVICE=your_service_name       # Oracle only
DB_DATABASE=your_database_name     # PostgreSQL only

# Oracle options
USE_DIAGNOSTICS_PACK=true          # Enable AWR/ASH profiling (requires license)
ORACLE_CLIENT_DIR=                 # Path to Oracle Instant Client (optional, uses default if empty)

# Notifications — both channels optional and independent.
# If both are configured, alerts fan out to both. If neither, the
# orchestrator runs silently (warning at startup).

# Discord (channel webhook)
DISCORD_WEBHOOK_URL=

# Telegram (bot token + chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

USER_NAME=your_name


# Named DB targets (optional). Lets callers say
# `run_sql("...", target="MR3")` without spelling out transport
# details. Each target is a set of `DB_TARGET_<NAME>_<FIELD>` keys.
# Fill these in here (this file is gitignored as `.env`); never hardcode
# a host, user, or password in the source — this repo is public.
#
# PREFERRED — a `direct` (SQLAlchemy) target connects straight to the
# database over the network, with no shell access to its host. Use this
# whenever the DB port is reachable (directly, or through a tunnel/VPN).
# It is the safest access path and the only one that is portable to run
# from a different machine.
#
# DB_TARGET_PG_TRANSPORT=direct
# DB_TARGET_PG_DIALECT=postgresql+psycopg2
# DB_TARGET_PG_USER=postgres
# DB_TARGET_PG_PASSWORD=
# DB_TARGET_PG_HOST=<host-or-tunnel-ip>
# DB_TARGET_PG_PORT=5432
# DB_TARGET_PG_DATABASE=your_database_name
#
# FALLBACK — `ssh+wsl` reaches a pgduckdb container on a remote WSL host
# over SSH (when the DB port is not exposed). Prefer `direct` instead.
#
# DB_TARGET_MR3_TRANSPORT=ssh+wsl
# DB_TARGET_MR3_SSH=user@host
# DB_TARGET_MR3_CONTAINER=pgduckdb
# DB_TARGET_MR3_PG_USER=postgres
# DB_TARGET_MR3_PG_DATABASE=your_database_name
# DB_TARGET_MR3_WSL=true
# DB_TARGET_MR3_SUDO=true
#
# FALLBACK — `ssh+clickhouse` reaches a ClickHouse container on a remote
# WSL host over SSH. Same `ssh + [wsl] [sudo] docker exec` envelope as
# `ssh+wsl`, but runs `clickhouse-client --format CSVWithNames`. Set
# `CH_DATABASE` to default the connection database, or leave it unset and
# qualify tables in the SQL (`SELECT … FROM mydb.mytable`).
#
# DB_TARGET_MR3_CH_TRANSPORT=ssh+clickhouse
# DB_TARGET_MR3_CH_SSH=user@host
# DB_TARGET_MR3_CH_CONTAINER=clickhouse-tabua
# DB_TARGET_MR3_CH_CH_DATABASE=your_database
# DB_TARGET_MR3_CH_WSL=true
# DB_TARGET_MR3_CH_SUDO=true
